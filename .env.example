# Oreon Build Service env
# copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://oreon:oreon@localhost:5432/oreon_build

# JWT / Session
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Default admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-secure-password

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rpmrepo-us
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# Worker
WORKER_ENROLLMENT_SECRET=change-me-worker-secret
CONTROLLER_URL=http://localhost:8000
MOCK_CONFIG_DIR=/etc/mock

# Signing — controller only (workers POST unsigned RPMs; controller signs then pushes to R2)
# Install rpm-sign on the controller host. Workers do not need GPG or rpm-sign for RPM artifacts.
SIGNING_KEY_ID=
SIGNING_KEY_GRIP=
GPG_HOME=/var/lib/oreon-build/gnupg

# Max size per RPM uploaded from worker to controller (MiB)
MAX_WORKER_RPM_UPLOAD_MIB=4096

# Integrations
# Discord webhook to receive audit and build events. (optional)
DISCORD_WEBHOOK_URL=
# Discord webhook dedicated to security advisories. (optional)
SECURITY_DISCORD_WEBHOOK_URL=

# Oreon Watchdog (security advisory dashboard)
WATCHDOG_URL=http://localhost:8001
WATCHDOG_CVE_SCAN_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO
