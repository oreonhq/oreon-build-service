CONTROLLER_URL=http://controller:8000
OREON_WORKER_TOKEN=
OREON_WORKER_NAME=worker-1

# Concurrent build threads on this host (default 4, capped ~8). Each job uses mock --uniqueext
# so chroots do not collide; very high values can still contend on mock’s shared caches.
# OREON_WORKER_MAX_JOBS=4

# Scratch + cleanup (recommended on busy workers so /tmp and /var/lib/mock do not fill up)
# Put worker job temp dirs under a dedicated path (created if missing):
# OREON_WORKER_TMP_PARENT=/var/tmp/oreon-build-worker
# Delete stale oreon-worker-* dirs under TMPDIR / OREON_WORKER_TMP_PARENT after N seconds (0 = off):
# OREON_WORKER_PRUNE_TMP_AGE_SEC=300
# mock --scrub=all timeout per job (seconds):
# OREON_WORKER_MOCK_SCRUB_TIMEOUT_SEC=3600

# R2 — used for build logs only (same bucket/creds as controller). RPMs are sent to the
# controller over HTTPS; the controller signs them and writes to R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=oreon-repos
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
