Description=Oreon Watchdog (Security Advisory Dashboard)
After=network.target postgresql.service

[Service]
Type=simple
User=oreon-build
Group=oreon-build
WorkingDirectory=/opt/oreon-build-service
EnvironmentFile=/opt/oreon-build-service/.env
ExecStart=/bin/sh -c 'port="${WATCHDOG_URL##*:}"; [ -z "$port" ] && port="8001"; /opt/oreon-build-service/venv/bin/python -m uvicorn oreon_build.watchdog.main:app --host 0.0.0.0 --port "$port"'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target

